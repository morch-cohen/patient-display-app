<Window x:Class="PatientDisplay.Views.DashboardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:PatientDisplay.ViewModels"
        xmlns:models="clr-namespace:PatientDisplay.Models"
        Title="Project M – Patient Dashboard"
        Icon="/Assets/project_m_logo.png"
        Width="420" Height="640"
        MinWidth="420" MinHeight="640"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterScreen"
        Topmost="True"
        Opacity="0">

    <!-- Fade-in on load -->
    <Window.Triggers>
        <EventTrigger RoutedEvent="Window.Loaded">
            <BeginStoryboard>
                <Storyboard>
                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                     From="0" To="1" Duration="0:0:0.2"/>
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </Window.Triggers>

    <Border Background="#F0F2F1" CornerRadius="20">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>  <!-- Header -->
                <RowDefinition Height="Auto"/>  <!-- Search -->
                <RowDefinition Height="*"/>     <!-- Patient list -->
                <RowDefinition Height="Auto"/>  <!-- Pagination -->
            </Grid.RowDefinitions>

            <!-- ── HEADER ── -->
            <Grid Grid.Row="0" Margin="24,20,24,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="PATIENTS" Style="{StaticResource LabelText}"/>
                    <TextBlock Style="{StaticResource HeadingLarge}" Margin="0,2,0,0">
                        <Run Text="Patients"/> <Run Text="List" Foreground="#FF2D55"/>
                    </TextBlock>
                    <TextBlock Margin="0,2,0,0">
                        <Run Text="{Binding TotalItems}" FontWeight="SemiBold" Foreground="#1A242B" FontFamily="Segoe UI" FontSize="13"/>
                        <Run Text=" patients" Foreground="#6B7280" FontFamily="Segoe UI" FontSize="13"/>
                    </TextBlock>
                </StackPanel>
                <!-- Close button -->
                <Button Grid.Column="1" Content="✕" Width="32" Height="32"
                        Background="White" BorderThickness="0"
                        FontSize="13" Foreground="#6B7280" Cursor="Hand"
                        Click="CloseButton_Click" VerticalAlignment="Top">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Root" Background="{TemplateBinding Background}"
                                    CornerRadius="8" Width="32" Height="32">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Root" Property="Background" Value="#FFE5EA"/>
                                    <Setter Property="Foreground" Value="#FF2D55"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>

            <!-- ── SEARCH BAR ── -->
            <Border Grid.Row="1" Margin="24,16,24,0" Background="White"
                    CornerRadius="12">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="8" ShadowDepth="1" Opacity="0.08" Color="#000000" Direction="270"/>
                </Border.Effect>
                <Grid>
                    <!-- Main text box spanning entire width -->
                    <TextBox Style="{StaticResource SearchBox}"
                             Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}"
                             Padding="38,10,12,10"
                             Background="Transparent"
                             x:Name="SearchBox"/>
                             
                    <!-- Magnifying glass icon overlay -->
                    <TextBlock Text="⌕" FontSize="16" Foreground="#9CA3AF"
                               VerticalAlignment="Center" Margin="16,0,0,0"
                               HorizontalAlignment="Left" IsHitTestVisible="False"/>
                               
                    <!-- Placeholder text overlay -->
                    <TextBlock Text="Search by name or ID…"
                               Foreground="#9CA3AF" FontFamily="Segoe UI" FontSize="13"
                               VerticalAlignment="Center" Margin="40,0,0,0"
                               HorizontalAlignment="Left" IsHitTestVisible="False"
                               Visibility="{Binding SearchQuery,
                                   Converter={StaticResource StringToVisibilityConverter},
                                   ConverterParameter=inverse}"/>
                </Grid>
            </Border>

            <!-- ── PATIENT LIST ── -->
            <Grid Grid.Row="2" Margin="0,12,0,0">
                <!-- Loading state -->
                <TextBlock Text="Loading patients…" HorizontalAlignment="Center"
                           VerticalAlignment="Center" Style="{StaticResource BodyText}"
                           Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}"/>

                <!-- Error state -->
                <TextBlock Text="{Binding ErrorMessage}" HorizontalAlignment="Center"
                           VerticalAlignment="Center" Foreground="#FF2D55" FontFamily="Segoe UI"
                           FontSize="13" TextWrapping="Wrap" Margin="24,0"
                           Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibilityConverter}}"/>

                <!-- Patient cards -->
                <ScrollViewer VerticalScrollBarVisibility="Hidden"
                              Visibility="{Binding IsLoading, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                    <ItemsControl ItemsSource="{Binding Patients}" Margin="24,0">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type models:PatientModel}">
                                <Border Style="{StaticResource CardBorder}" Cursor="Hand"
                                        MouseLeftButtonUp="PatientCard_Click"
                                        Tag="{Binding}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="{Binding FullName}"
                                                       Style="{StaticResource HeadingMedium}"/>
                                            <TextBlock Margin="0,4,0,0">
                                                <Run Text="ID: " Foreground="#9CA3AF" FontFamily="Segoe UI" FontSize="12"/>
                                                <Run Text="{Binding Id}" Foreground="#6B7280" FontFamily="Segoe UI" FontSize="12"/>
                                                <Run Text="  ·  " Foreground="#9CA3AF" FontFamily="Segoe UI" FontSize="12"/>
                                                <Run Text="{Binding Age}" Foreground="#6B7280" FontFamily="Segoe UI" FontSize="12"/>
                                                <Run Text=" yrs  ·  " Foreground="#9CA3AF" FontFamily="Segoe UI" FontSize="12"/>
                                                <Run Text="{Binding Gender}" Foreground="#6B7280" FontFamily="Segoe UI" FontSize="12"/>
                                            </TextBlock>
                                            <TextBlock Text="{Binding Diagnosis}" Style="{StaticResource BodyText}"
                                                       FontSize="11" Margin="0,4,0,0"
                                                       TextTrimming="CharacterEllipsis"/>
                                        </StackPanel>

                                        <!-- Status pill -->
                                        <Border Grid.Column="1" VerticalAlignment="Top"
                                                CornerRadius="20" Padding="10,4">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding SurgicalStatus}" Value="Cleared">
                                                            <Setter Property="Background" Value="#E6F7F8"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding SurgicalStatus}" Value="Pending">
                                                            <Setter Property="Background" Value="#FFE9ED"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock Text="{Binding SurgicalStatus}" FontFamily="Segoe UI"
                                                       FontSize="11" FontWeight="SemiBold">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding SurgicalStatus}" Value="Cleared">
                                                                <Setter Property="Foreground" Value="#00A3AD"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding SurgicalStatus}" Value="Pending">
                                                                <Setter Property="Foreground" Value="#FF2D55"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Border>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>

            <!-- ── PAGINATION ── -->
            <Grid Grid.Row="3" Margin="24,8,24,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" Content="← Prev" Style="{StaticResource GhostButton}"
                        Command="{Binding PreviousPageCommand}"/>
                <TextBlock Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center"
                           FontFamily="Segoe UI" FontSize="12" Foreground="#6B7280">
                    <Run Text="Page "/>
                    <Run Text="{Binding CurrentPage}" FontWeight="SemiBold" Foreground="#1A242B"/>
                    <Run Text=" of "/>
                    <Run Text="{Binding TotalPages}" FontWeight="SemiBold" Foreground="#1A242B"/>
                </TextBlock>
                <Button Grid.Column="2" Content="Next →" Style="{StaticResource GhostButton}"
                        Command="{Binding NextPageCommand}"/>
            </Grid>
        </Grid>
    </Border>
</Window>
