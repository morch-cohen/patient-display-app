<Window x:Class="PatientDisplay.Views.PatientDetailWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:PatientDisplay.ViewModels"
        Title="Patient Detail"
        Icon="/Assets/project_m_logo.png"
        Width="480" SizeToContent="Height"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Topmost="True"
        Opacity="0">

    <Window.Triggers>
        <EventTrigger RoutedEvent="Window.Loaded">
            <BeginStoryboard>
                <Storyboard>
                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                     From="0" To="1" Duration="0:0:0.2"/>
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </Window.Triggers>

    <Border CornerRadius="20">
        <!-- Dynamic background: teal-tinted for Cleared, default for Pending -->
        <Border.Style>
            <Style TargetType="Border">
                <Setter Property="Background" Value="#F0F2F1"/>
                <Style.Triggers>
                    <DataTrigger Binding="{Binding IsCleared}" Value="True">
                        <Setter Property="Background" Value="#EEF9F9"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>
        </Border.Style>
        <!-- Main Content Panel (No Scrolling) -->
        <StackPanel Margin="20">

                <!-- Header row -->
                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="PATIENT DETAIL" Style="{StaticResource LabelText}"/>
                    <Button Grid.Column="1" Content="✕" Click="CloseButton_Click"
                            Background="White" BorderThickness="0"
                            FontSize="13" Foreground="#6B7280" Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Root" Background="{TemplateBinding Background}"
                                        CornerRadius="8" Width="32" Height="32">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Root" Property="Background" Value="#FFE5EA"/>
                                        <Setter Property="Foreground" Value="#FF2D55"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>

                <!-- Patient Identity -->
                <StackPanel Margin="0,0,0,20">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{Binding Patient.FullName}" Style="{StaticResource HeadingLarge}"/>
                        <TextBlock Margin="6,0,0,2" VerticalAlignment="Bottom">
                            <Run Text="{Binding Patient.Age}" FontWeight="Normal" Foreground="{StaticResource TextSecondaryBrush}" FontSize="18"/>
                            <Run Text=", " FontWeight="Normal" Foreground="{StaticResource TextSecondaryBrush}" FontSize="18"/>
                            <Run Text="{Binding Patient.Gender}" FontWeight="Normal" Foreground="{StaticResource TextSecondaryBrush}" FontSize="18"/>
                        </TextBlock>
                    </StackPanel>
                    <TextBlock Text="{Binding Patient.Id}" FontFamily="Segoe UI"
                               FontSize="12" Foreground="{StaticResource TextMutedBrush}" Margin="0,2,0,0"/>
                </StackPanel>

                <!-- Diagnosis Card -->
                <Border Style="{StaticResource CardBorder}">
                    <StackPanel>
                        <TextBlock Text="DIAGNOSIS" Style="{StaticResource LabelText}" Margin="0,0,0,8"/>
                        <TextBlock Text="{Binding Patient.Diagnosis}"
                                   Style="{StaticResource HeadingMedium}"/>
                    </StackPanel>
                </Border>

                <!-- Clinical Summary Card -->
                <Border Style="{StaticResource CardBorder}">
                    <StackPanel>
                        <TextBlock Text="CLINICAL SUMMARY" Style="{StaticResource LabelText}" Margin="0,0,0,8"/>
                        <TextBlock Text="{Binding Patient.ClinicalSummary}"
                                   Style="{StaticResource BodyText}" LineHeight="22"/>
                    </StackPanel>
                </Border>

                <!-- Surgical Status Card -->
                <Border CornerRadius="16" Padding="20" Margin="0,0,0,12">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Background" Value="White"/>
                            <Setter Property="Effect">
                                <Setter.Value>
                                    <DropShadowEffect BlurRadius="15" ShadowDepth="2" Opacity="0.12" Color="#000000" Direction="270"/>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Border.Style>
                    <StackPanel>
                        <TextBlock Text="SURGICAL STATUS" Style="{StaticResource LabelText}" Margin="0,0,0,12"/>

                        <!-- Pill Toggle Button -->
                        <Button Command="{Binding ToggleStatusCommand}" Margin="0,0,0,16" Cursor="Hand" BorderThickness="0" Background="Transparent">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="Container" CornerRadius="24" Height="48" Background="#00A3AD">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>

                                            <!-- Cleared Option -->
                                            <Border x:Name="ClearedBg" Grid.Column="0" Background="White" CornerRadius="20" Margin="4">
                                                <TextBlock x:Name="ClearedText" Text="Cleared" HorizontalAlignment="Center" VerticalAlignment="Center"
                                                           FontFamily="Segoe UI" FontSize="14" FontWeight="Bold" Foreground="#00A3AD"/>
                                            </Border>

                                            <!-- Pending Option -->
                                            <Border x:Name="PendingBg" Grid.Column="1" Background="Transparent" CornerRadius="20" Margin="4">
                                                <TextBlock x:Name="PendingText" Text="Pending" HorizontalAlignment="Center" VerticalAlignment="Center"
                                                           FontFamily="Segoe UI" FontSize="14" FontWeight="Bold" Foreground="White"/>
                                            </Border>
                                        </Grid>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <DataTrigger Binding="{Binding IsCleared}" Value="False">
                                            <!-- Switch to Pink theme -->
                                            <Setter TargetName="Container" Property="Background" Value="#FF2D55"/>
                                            
                                            <!-- Swap backgrounds -->
                                            <Setter TargetName="ClearedBg" Property="Background" Value="Transparent"/>
                                            <Setter TargetName="PendingBg" Property="Background" Value="White"/>
                                            
                                            <!-- Swap text colors -->
                                            <Setter TargetName="ClearedText" Property="Foreground" Value="White"/>
                                            <Setter TargetName="PendingText" Property="Foreground" Value="#FF2D55"/>
                                        </DataTrigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <!-- Save button -->
                        <Button Command="{Binding SaveStatusCommand}" Height="42" Cursor="Hand" Foreground="White" FontFamily="Segoe UI" FontSize="13" FontWeight="SemiBold" BorderThickness="0">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Background" Value="#00A3AD"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="Root" Background="{TemplateBinding Background}" CornerRadius="10" Padding="24,10">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <!-- Teal Hover -->
                                                    <MultiDataTrigger>
                                                        <MultiDataTrigger.Conditions>
                                                            <Condition Binding="{Binding IsMouseOver, RelativeSource={RelativeSource Self}}" Value="True"/>
                                                            <Condition Binding="{Binding IsCleared}" Value="True"/>
                                                        </MultiDataTrigger.Conditions>
                                                        <Setter TargetName="Root" Property="Background" Value="#008A93"/>
                                                    </MultiDataTrigger>
                                                    <!-- Pink Hover -->
                                                    <MultiDataTrigger>
                                                        <MultiDataTrigger.Conditions>
                                                            <Condition Binding="{Binding IsMouseOver, RelativeSource={RelativeSource Self}}" Value="True"/>
                                                            <Condition Binding="{Binding IsCleared}" Value="False"/>
                                                        </MultiDataTrigger.Conditions>
                                                        <Setter TargetName="Root" Property="Background" Value="#D81F42"/>
                                                    </MultiDataTrigger>
                                                    <!-- Disabled -->
                                                    <Trigger Property="IsEnabled" Value="False">
                                                        <Setter TargetName="Root" Property="Background" Value="#D1D5DB"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsCleared}" Value="False">
                                            <Setter Property="Background" Value="#FF2D55"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <StackPanel Orientation="Horizontal">
                                <!-- Spinner while saving -->
                                <TextBlock Text="Saving…" FontFamily="Segoe UI" FontSize="13" FontWeight="SemiBold"
                                           VerticalAlignment="Center"
                                           Visibility="{Binding IsSaving, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                <TextBlock Text="Save Status" FontFamily="Segoe UI" FontSize="13" FontWeight="SemiBold"
                                           VerticalAlignment="Center"
                                           Visibility="{Binding IsSaving, Converter={StaticResource InverseBoolToVisibilityConverter}}"/>
                            </StackPanel>
                        </Button>

                        <!-- Message Container to prevent layout jump -->
                        <Grid Height="20" Margin="0,8,0,0">
                            <!-- Success message -->
                            <TextBlock Text="✓ Status saved successfully!" FontFamily="Segoe UI"
                                       FontSize="12" Foreground="#00A3AD" HorizontalAlignment="Center"
                                       Visibility="{Binding SaveSuccess, Converter={StaticResource BoolToVisibilityConverter}}"/>

                            <!-- Error message -->
                            <TextBlock Text="{Binding SaveError}" FontFamily="Segoe UI"
                                       FontSize="12" Foreground="#FF2D55" HorizontalAlignment="Center"
                                       TextWrapping="Wrap"
                                       Visibility="{Binding SaveError, Converter={StaticResource StringToVisibilityConverter}}"/>
                        </Grid>
                    </StackPanel>
                </Border>

            </StackPanel>
    </Border>
</Window>
